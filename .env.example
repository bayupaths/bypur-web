# Portfolio Admin API — server-side only (never exposed to browser)
NUXT_API_KEY=your-secret-api-key-here

# Base URL of portfolio-admin backend
# Local dev (tanpa Docker):  http://localhost:8080
# Docker (shared network):   http://portfolio_admin_nginx
NUXT_PUBLIC_API_BASE=http://portfolio_admin_nginx

# Docker port (default: 3000)
PORT=3000
