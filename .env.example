# Environment Variables - Portfolio Pribadi
# Copy file ini ke .env.local dan sesuaikan nilai sesuai kebutuhan

# Backend API URL (opsional)
NEXT_PUBLIC_API_URL=

# Flag untuk menggunakan backend API
NEXT_PUBLIC_USE_BACKEND=false

# CDN Base URL untuk assets
NEXT_PUBLIC_CDN_BASE=https://cdn.bypur.my.id

# AI provider API key
# OPENAI_API_KEY=sk-your-actual-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_API_REVISION=2026-05-20

# Environment
NODE_ENV=development
