# Environment Variables untuk Portfolio Pribadi
# Copy file ini ke .env.local

# Backend API (opsional - untuk portfolio pribadi biasanya tidak perlu)
# Default: gunakan static data saja
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_USE_BACKEND=false

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=development

# =============================================================================
# OPTIONAL: THIRD-PARTY SERVICES
# =============================================================================
# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Contact Form API (e.g., FormSpree, EmailJS)
# NEXT_PUBLIC_CONTACT_FORM_API=https://formspree.io/f/your-form-id

# =============================================================================
# SECURITY
# =============================================================================
# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting (requests per minute)
RATE_LIMIT=60
